# NOTE: knightgroup.com is hosted on GitHub Pages (see CNAME).
# Apache/.htaccess rules are NOT applied in production.
# DNS at GoDaddy only points the domain here — keep this file for reference
# if the site is ever moved to GoDaddy/cPanel hosting.

# Knight Group — Apache clean URLs + SEO redirects (reference only on GitHub Pages)
Options -Indexes
DirectoryIndex index.html

RewriteEngine On
RewriteBase /

RewriteCond %{HTTP_HOST} ^knightgroup\.com$ [NC]
RewriteRule ^ https://www.knightgroup.com%{REQUEST_URI} [R=301,L]

RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
RewriteCond %1 !^(header|footer|head-gtm|socialCards|page-template)$ [NC]
RewriteCond %1 !^PolicyPages/(header|footer)$ [NC]
RewriteRule ^ /%1 [R=301,L]

RewriteRule ^services/?$ services.html [L,NC]

RewriteRule ^Services/?$ /services [R=301,L]

RewriteRule ^services/([^/]+)/?$ /Services/$1 [R=301,L,NC]

RewriteRule ^Services/programming(?:%26|&)databases/?$ https://knightlogics.com/service-ai-automation [R=301,L,NC]
RewriteRule ^Services/handcraftedfurniture(?:%26|&)resins/?$ /Services/custom-projects [R=301,L,NC]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+?)/?$ $1.html [L]
