# Knight Group — GoDaddy / Apache clean URLs + SEO redirects
Options -Indexes
DirectoryIndex index.html

RewriteEngine On
RewriteBase /

# Canonical host: bare domain → www
RewriteCond %{HTTP_HOST} ^knightgroup\.com$ [NC]
RewriteRule ^ https://www.knightgroup.com%{REQUEST_URI} [R=301,L]

# Strip .html from public URLs (keep include partials untouched)
RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
RewriteCond %1 !^(header|footer|head-gtm|socialCards|page-template)$ [NC]
RewriteCond %1 !^PolicyPages/(header|footer)$ [NC]
RewriteRule ^ /%1 [R=301,L]

# Services hub MUST resolve to services.html (not Services/ directory index)
RewriteRule ^services/?$ services.html [L,NC]

# /Services/ folder root → canonical hub
RewriteRule ^Services/?$ /services [R=301,L]

# Lowercase /services/slug → canonical /Services/slug
RewriteRule ^services/([^/]+)/?$ /Services/$1 [R=301,L,NC]

# Legacy / retired URLs
RewriteRule ^Services/programming(?:%26|&)databases/?$ https://knightlogics.com/service-ai-automation [R=301,L,NC]
RewriteRule ^Services/handcraftedfurniture(?:%26|&)resins/?$ /Services/custom-projects [R=301,L,NC]

# Extensionless URLs → matching .html when present
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+?)/?$ $1.html [L]

# Sitemap MIME
<IfModule mod_mime.c>
  AddType application/xml .xml
</IfModule>

# Security / cache hints for static assets
<IfModule mod_headers.c>
  <FilesMatch "\.(webp|jpg|jpeg|png|gif|svg|woff2|css|js)$">
    Header set Cache-Control "public, max-age=604800"
  </FilesMatch>
</IfModule>
